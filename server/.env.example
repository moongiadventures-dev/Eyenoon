# Template for server/.env — copy to ".env" and fill in real values.
# This .example file is safe to commit; the real .env must NEVER be committed.

PORT=4242
PUBLIC_SITE_URL=http://127.0.0.1:5500
ALLOWED_ORIGIN=http://127.0.0.1:5500
CURRENCY=usd

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Resend transactional email (order receipts). Sign up at resend.com.
# Until you verify a domain, FROM_EMAIL must use Resend's default sender
# and recipients are limited to your Resend account email.
RESEND_API_KEY=
FROM_EMAIL=Eye Noon Optical <onboarding@resend.dev>
BCC_EMAIL=
